      "source": [
        "import numpy as np\n",
        "\n",
        "A = np.array([[4, 1], [2, 3]])\n",
        "eigenvalues, eigenvectors = np.linalg.eig(A)\n",
        "\n",
        "print('Matrix A:')\n",
        "print(A)\n",
        "print('\\nEigenvalues:', eigenvalues)\n",
        "print('\\nEigenvectors:\\n', eigenvectors)"
      ],
